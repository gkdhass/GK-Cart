# ═══════════════════════════════════════════════
# K_M_Cart Client Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════

# ── BACKEND API URL ─────────────────────────────
# Development: Leave empty (uses Vite proxy to http://localhost:5000)
# Production: https://your-backend.vercel.app (NO trailing slash!)
VITE_API_URL=

# ═══════════════════════════════════════════════
# Firebase Configuration (for Google Login & Storage)
# ═══════════════════════════════════════════════
# Get from: Firebase Console → Project Settings → General → Your apps
# These are PUBLIC keys (safe to expose in client-side code)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
